# --- Arc Testnet ---
# RPC endpoint for Arc Testnet
RPC_URL=https://rpc.testnet.arc.network

# Funded Arc Testnet wallet private key used as the "platform liquidity / Gateway"
# wallet that custodies USDC in transit between sender and the simulated
# mobile-money cash-out step. Fund via https://faucet.circle.com/
PLATFORM_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# --- Circle Developer Console ---
# https://console.circle.com/signup
CIRCLE_API_KEY=YOUR_CIRCLE_API_KEY
CIRCLE_ENTITY_SECRET=YOUR_CIRCLE_ENTITY_SECRET

# Circle Wallets (Developer-Controlled) wallet set id, created once via
# Circle's Wallets API and reused for every sender/recipient wallet.
CIRCLE_WALLET_SET_ID=YOUR_WALLET_SET_ID

# Circle Gateway endpoint / unified balance API base (placeholder; confirm
# exact path in current Circle docs before going live — see lib/gateway.ts)
CIRCLE_GATEWAY_API_BASE=https://api.circle.com/v1/w3s

# --- App ---
NEXT_PUBLIC_APP_NAME=RemitArc
NEXT_PUBLIC_ARC_EXPLORER=https://testnet.arcscan.app
